rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated();
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Data Validation Functions
    // ===============================================================

    function isValidStudent(data) {
      return hasOnlyAllowedFields(['id', 'name', 'class', 'marks', 'image', 'docId', 'examType', 'section', 'studentId', 'hallTicketAvailable']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.class is string &&
             data.marks is map &&
             (!('image' in data) || data.image == null || (data.image is string && data.image.size() < 2000000)) &&
             (!('docId' in data) || data.docId is string) &&
             (!('examType' in data) || data.examType is string) &&
             (!('section' in data) || data.section is string) &&
             (!('studentId' in data) || data.studentId is string) &&
             (!('hallTicketAvailable' in data) || data.hallTicketAvailable is bool);
    }

    function isValidSubject(data) {
      return hasOnlyAllowedFields(['id', 'name', 'maxMarks', 'passMarks', 'type', 'examDate', 'examTime', 'room']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.maxMarks is number && data.maxMarks > 0 &&
             data.passMarks is number && data.passMarks >= 0 &&
             (!('type' in data) || data.type is string) &&
             (!('examDate' in data) || data.examDate is string) &&
             (!('examTime' in data) || data.examTime is string) &&
             (!('room' in data) || data.room is string);
    }

    function isValidAttendance(data) {
      return hasOnlyAllowedFields(['id', 'studentId', 'studentName', 'class', 'date', 'status']) &&
             data.id is string &&
             data.studentId is string &&
             data.studentName is string &&
             data.class is string &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.status in ['Present', 'Absent', 'Late'];
    }

    function isValidSettings(data) {
      return hasOnlyAllowedFields(['adminPassword', 'examCenter', 'subjectTypes']) &&
             (!('adminPassword' in data) || (data.adminPassword is string && data.adminPassword.size() >= 4)) &&
             (!('examCenter' in data) || data.examCenter is string) &&
             (!('subjectTypes' in data) || data.subjectTypes is list);
    }

    function isValidNotification(data) {
      return hasOnlyAllowedFields(['id', 'title', 'content', 'date', 'important']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 100 &&
             (!('important' in data) || data.important is bool);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /students/{studentId} {
      allow read: if true;
      allow create, update: if isAdmin() || isValidStudent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow create, update: if isAdmin() || isValidSubject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if true;
      allow create, update: if isAdmin() || isValidAttendance(request.resource.data);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update: if isAdmin() || isValidNotification(request.resource.data);
      allow delete: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() || 
                             (!exists(/databases/$(database)/documents/settings/admin) && isValidSettings(request.resource.data)) ||
                             (exists(/databases/$(database)/documents/settings/admin) && isValidSettings(request.resource.data));
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
